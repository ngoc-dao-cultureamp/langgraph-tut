{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.12",
    "path:.#default",
    "llama-cpp@latest",
    "uv@latest"
  ],
  "shell": {
    "init_hook": [
      "export PGDATA=\"$PWD/.pgdata\"",
      "export PYTHONPATH=\"$PWD/src\"",
      "export BOOKS_DIR=\"$PWD/sherlock_holmes\""
    ],
    "env": {
      "PGHOST": "localhost",
      "PGUSER": "postgres",
      "PGDATABASE": "ragdb",
      "DB_URL": "postgresql+psycopg://postgres@localhost:5432/ragdb",
      "LLM_HOST": "http://localhost:8080/v1",
      "EMBED_HOST": "http://localhost:8081/v1",
      "LLM_MODEL": "qwen2.5-32b-instruct",
      "EMBED_MODEL": "nomic-embed-text-v1.5"
    },
    "scripts": {
      "db-reset": [
        "pg_ctl stop -D $PGDATA || true",
        "rm -rf $PGDATA",
        "initdb --pgdata=$PGDATA --username=postgres",
        "pg_ctl start -D $PGDATA -l $PGDATA/postgres.log",
        "createdb -U postgres ragdb",
        "psql -U postgres -d ragdb -c 'CREATE EXTENSION IF NOT EXISTS vector;'",
        "pg_ctl stop -D $PGDATA"
      ],
      "model-pull": ["huggingface-cli download Qwen/Qwen2.5-32B-Instruct-GGUF qwen2.5-32b-instruct-q4_k_m.gguf --local-dir models/", "huggingface-cli download nomic-ai/nomic-embed-text-v1.5-GGUF nomic-embed-text-v1.5.Q8_0.gguf --local-dir models/"],
      "ui": ["uv run streamlit run src/ui.py"]
    }
  }
}
