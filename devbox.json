{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.12",
    "path:.#pg_with_pgvector",
    "uv@latest"
  ],
  "shell": {
    "init_hook": [
      "[ -f \"$PWD/local.env\" ] && . \"$PWD/local.env\"",
      ": ${LLAMA_SERVER_BIN:?LLAMA_SERVER_BIN must be set in local.env}",
      "export LLAMA_SERVER_BIN",
      "export PYTHONPATH=\"$PWD/src\"",
      "export BOOKS_DIR=\"$PWD/sherlock_holmes\"",
      "export PGDATA=\"$PWD/.pgdata\"",
      "export PGHOST=localhost",
      "export PGUSER=postgres",
      "export PGDATABASE=ragdb",
      "export DB_URL=postgresql+psycopg://postgres@localhost:5432/ragdb",
      "export LLM_HOST=http://localhost:8080/v1",
      "export EMBED_HOST=http://localhost:8081/v1",
      "export LLM_REPO=LuffyTheFox/Qwen3.6-35B-A3B-Uncensored-Wasserstein-GGUF",
      "export LLM_FILE=Qwen3.6-35B-A3B-Uncensored.Q4_K_P.gguf",
      "export LLM_MODEL_ALIAS=qwen3.6-35b-a3b",
      "export EMBED_REPO=nomic-ai/nomic-embed-text-v1.5-GGUF",
      "export EMBED_FILE=nomic-embed-text-v1.5.Q8_0.gguf",
      "export EMBED_MODEL_ALIAS=nomic-embed-text-v1.5",
      "export MODELS_DIR=\"$HOME/models\""
    ],
    "scripts": {
      "db-reset": [
        "pg_ctl stop -D $PGDATA || true",
        "rm -rf $PGDATA"
      ],
      "model-pull": ["uv run hf download $LLM_REPO $LLM_FILE --local-dir $MODELS_DIR", "uv run hf download $EMBED_REPO $EMBED_FILE --local-dir $MODELS_DIR"],
      "eval": ["uv run python src/cli/eval.py"],
      "lint": ["uv run ruff check src/"],
      "fmt": ["uv run ruff format src/"],
      "webui": ["uv run streamlit run src/webui.py"]
    }
  }
}
