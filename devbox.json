{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.2/.schema/devbox.schema.json",
  "packages": [
    "python@3.12",
    "path:.#default",
    "llama-cpp@latest",
    "uv@latest"
  ],
  "shell": {
    "init_hook": [
      "export PGDATA=\"$PWD/.pgdata\"",
      "export PYTHONPATH=\"$PWD/src\"",
      "export BOOKS_DIR=\"$PWD/sherlock_holmes\"",
      "export PGHOST=localhost",
      "export PGUSER=postgres",
      "export PGDATABASE=ragdb",
      "export DB_URL=postgresql+psycopg://postgres@localhost:5432/ragdb",
      "export LLM_HOST=http://localhost:8080/v1",
      "export EMBED_HOST=http://localhost:8081/v1",
      "export LLM_MODEL=qwen3.6-27b-instruct",
      "export LLM_FILE=qwen3.6-27b-abliterated-Q4_K_M.gguf",
      "export LLM_REPO=Abiray/Huihui-Qwen3.6-27B-abliterated-GGUF",
      "export EMBED_MODEL=nomic-embed-text-v1.5",
      "export EMBED_FILE=nomic-embed-text-v1.5.Q8_0.gguf",
      "export EMBED_REPO=nomic-ai/nomic-embed-text-v1.5-GGUF"
    ],
    "scripts": {
      "db-reset": [
        "pg_ctl stop -D $PGDATA || true",
        "rm -rf $PGDATA",
        "initdb --pgdata=$PGDATA --username=postgres",
        "pg_ctl start -D $PGDATA -l $PGDATA/postgres.log",
        "createdb -U postgres ragdb",
        "psql -U postgres -d ragdb -c 'CREATE EXTENSION IF NOT EXISTS vector;'",
        "pg_ctl stop -D $PGDATA"
      ],
      "model-pull": ["uv run hf download $LLM_REPO $LLM_FILE --local-dir models/", "uv run hf download $EMBED_REPO $EMBED_FILE --local-dir models/"],
      "eval": ["uv run python src/eval.py"],
      "ui": ["uv run streamlit run src/ui.py"]
    }
  }
}
